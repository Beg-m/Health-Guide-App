{
  "expo": {
    "name": "Health Guide App",
    "slug": "health-guide-app",
    "scheme": "healthguideapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Tarif paylaşmak için fotoğraf ve videolarınıza erişmemiz gerekir.",
          "cameraPermission": "İsterseniz kameradan fotoğraf veya video çekebilirsiniz."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "25cf121f-fc62-4fc9-b97f-dfdc6f945fc0"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/25cf121f-fc62-4fc9-b97f-dfdc6f945fc0"
    }
  }
}

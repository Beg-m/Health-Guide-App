rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isReminderShape(data) {
      return data.keys().hasAll([
        'medicationName', 'dose', 'time', 'days', 'isActive', 'createdAt'
      ])
      && data.medicationName is string
      && data.dose is string
      && data.time is list
      && data.days is list
      && data.isActive is bool
      && data.createdAt is string;
    }

    // familyGroups/{groupId}.members içinde hem okuyucu hem koleksiyon sahibi var mı?
    function shareFamilyGroupMembers(readerUid, ownerUid) {
      let readerDoc = get(/databases/$(database)/documents/users/$(readerUid));
      let ownerDoc = get(/databases/$(database)/documents/users/$(ownerUid));
      let groupId = readerDoc.data.familyGroupId;
      return groupId != null
        && groupId == ownerDoc.data.familyGroupId
        && exists(/databases/$(database)/documents/familyGroups/$(groupId))
        && readerUid in get(/databases/$(database)/documents/familyGroups/$(groupId)).data.members
        && ownerUid in get(/databases/$(database)/documents/familyGroups/$(groupId)).data.members;
    }

    // users/{ownerUid}/reminders okuma: yalnızca sahip veya aynı aile grubundaki üye
    function canReadUserReminders(ownerUid) {
      return isOwner(ownerUid)
        || (isSignedIn() && shareFamilyGroupMembers(request.auth.uid, ownerUid));
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /reminders/{reminderId} {
        allow read: if canReadUserReminders(userId);

        allow create, update: if isOwner(userId)
          && isReminderShape(request.resource.data);

        allow delete: if isOwner(userId);
      }

      match /following/{targetUid} {
        allow read, write: if isOwner(userId);
      }

      match /followers/{followerUid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /favorites/{recipeId} {
        allow read, write: if isOwner(userId);
      }

      match /conversations/{convId} {
        allow read, write: if isOwner(userId);

        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    match /recipes/{recipeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
    }

    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.mediaURL is string
        && request.resource.data.mediaType in ["photo", "video"]
        && request.resource.data.createdAt is string
        && request.resource.data.expiresAt is string;
      allow delete: if isSignedIn() && (
        resource.data.uid == request.auth.uid
        || (
          resource.data.keys().hasAny(["expiresAtMs"])
          && resource.data.expiresAtMs is number
          && resource.data.expiresAtMs <= request.time.toMillis()
        )
      );
    }

    match /familyGroups/{groupId} {
      // inviteCode ile sorgu (joinFamilyGroup) için giriş yapmış kullanıcılar okuyabilir
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members is list
        && request.resource.data.inviteCode is string
        && request.resource.data.name is string;

      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.members
        || (
          request.auth.uid in request.resource.data.members
          && !(request.auth.uid in resource.data.members)
          && request.resource.data.members.size() == resource.data.members.size() + 1
        )
      );

      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
    }
  }
}
